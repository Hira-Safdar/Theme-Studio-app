<?xml version="1.0" encoding="utf-8"?>
<!-- "Gradient" style app ke accent (cyan) se ek violet tone tak
     diagonal gradient, sab widgets ke liye consistent recipe. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="16dp" />
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#FF00FFF0"
        android:endColor="#FF8B7CFF" />
</shape>