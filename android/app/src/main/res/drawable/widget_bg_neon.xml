<?xml version="1.0" encoding="utf-8"?>
<!-- "Neon Glass" style pure XML mein real blur possible nahi (jaisa
     Kotlin Canvas mein BlurMaskFilter se hota hai), isliye glow ka
     approximation 3 concentric layers se karte hain: sabse bahar ek bohot
     halka (low-alpha) stroke ring, phir thoda strong ring, phir andar ek
     dark glass card jiska border bright hai. Result  ek soft neon-glow
     jaisa effect, static drawable hote hue bhi. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow sabse halka, sabse bada -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <stroke android:width="8dp" android:color="#2200FFF0" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- Middle glow ring -->
    <item
        android:top="3dp"
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <stroke android:width="4dp" android:color="#4400FFF0" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <!-- Dark glass card + bright inner stroke -->
    <item
        android:top="6dp"
        android:bottom="6dp"
        android:left="6dp"
        android:right="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#E60A0A12" />
            <stroke android:width="1.5dp" android:color="#9900FFF0" />
        </shape>
    </item>
</layer-list>